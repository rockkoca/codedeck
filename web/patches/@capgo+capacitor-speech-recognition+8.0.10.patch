+    // MARK: - Audio level metering
+
+    private func emitAudioLevel(buffer: AVAudioPCMBuffer) {
+        let now = CACurrentMediaTime()
+        // Throttle to ~15 fps (every 66ms)
+        guard now - lastLevelTime > 0.066 else { return }
+        lastLevelTime = now
+
+        guard let channelData = buffer.floatChannelData else { return }
+        let frames = Int(buffer.frameLength)
+        guard frames > 0 else { return }
+
+        // Calculate RMS
+        var sum: Float = 0
+        let data = channelData[0]
+        for i in 0..<frames {
+            let sample = data[i]
+            sum += sample * sample
+        }
+        let rms = sqrtf(sum / Float(frames))
+
+        // Convert to 0..1 range (dB scale, -60dB to 0dB mapped to 0..1)
+        let db = 20.0 * log10f(max(rms, 1e-6))
+        let level = max(0, min(1, (db + 50) / 50))
+
+        DispatchQueue.main.async { [weak self] in
+            self?.notifyListeners("audioLevel", data: ["level": level])
+        }
+    }
