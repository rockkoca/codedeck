  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "miniflare": "^3.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0",
    "wrangler": "^3.0.0"
  }
}
