# Cloudflare Worker
CF_WORKER_URL=https://codedeck.your-subdomain.workers.dev
CF_API_KEY=your_api_key_here

# Discord
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_APP_ID=your_discord_app_id
DISCORD_PUBLIC_KEY=your_discord_public_key

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_SECRET_TOKEN=your_telegram_secret_token

# Feishu
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_VERIFICATION_TOKEN=your_feishu_verification_token
FEISHU_ENCRYPT_KEY=your_feishu_encrypt_key

# Issue Trackers
GITHUB_TOKEN=your_github_token
GITLAB_TOKEN=your_gitlab_token

# Memory backends (optional)
CLAUDE_MEM_URL=http://localhost:37777
MEM0_URL=http://localhost:37778
