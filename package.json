{
  "name": "codedeck",
  "version": "0.1.0",
  "description": "Remote control AI coding agents (Claude Code, Codex, OpenCode) via chat platforms and web terminal",
  "license": "MIT",
  "bin": {
    "codedeck": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist/",
    "config/"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.ts",
    "test": "vitest run",
    "test:unit": "vitest run --project daemon",
    "test:server": "vitest run --project server",
    "test:worker": "vitest run --project worker",
    "test:web": "vitest run --project web",
    "test:e2e": "vitest run --project e2e",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run test:unit && npm run test:server && npm run test:worker && npm run test:web"
  },
  "dependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.59.0",
    "commander": "^12.1.0",
    "octokit": "^4.0.2",
    "pino": "^9.5.0",
    "tsx": "^4.19.0",
    "ws": "^8.18.0",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.13",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^9.0.0",
    "hono": "^4.12.5",
    "jsdom": "^28.1.0",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "zod": "^4.3.6"
  }
}
